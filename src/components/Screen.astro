---
import Icon from "./Icon.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
import { PROFILE } from "@/constants";
---

<div
  class="flex w-full flex-shrink-0 flex-col items-center justify-between bg-muted sm:h-screen"
>
  <div class="min-h-14"></div>
  <div
    class="mt-12 mb-4 flex flex-col items-center gap-x-10 gap-y-5 sm:mt-14 sm:mb-14 sm:flex-row"
  >
    <div
      class="flex h-24 w-24 items-center overflow-hidden rounded-full sm:h-52 sm:w-52"
    >
      <img class="w-full scale-150" src={PROFILE.avatar} alt="" />
    </div>
    <div class="space-y-2 text-center sm:text-left">
      <h2
        class="animate__animated animate__fadeInUp animate__delay-1s text-2xl sm:text-4xl"
      >
        <span>Hi, I'm {SITE.author} </span>
        <span class="animate-wave inline-block">👋</span>
      </h2>
      <h3
        class="animate__animated animate__fadeInUp animate__delay-2s text-lg sm:text-lg"
      >
        {PROFILE.synopsis}
      </h3>
      <LinkButton
        class="hover:text-skin-accent animate__animated animate__fadeInUp animate__delay-3s text-2xl underline decoration-dashed underline-offset-4 sm:text-4xl"
        href="/posts">Blogs</LinkButton
      >
    </div>
  </div>
  <a href="#about-me" class="animate-bounce pb-2 sm:block">
    <Icon name="ArrowDown" class="size-6 stroke-1" />
  </a>
</div>
