---
// Skeleton loading component for PDF viewer
---

<div class="animate__animated animate__fadeIn w-full space-y-4">
  <!-- PDF Page Skeleton 1 -->
  <div class="overflow-hidden rounded-sm bg-white shadow-sm dark:bg-gray-800">
    <div class="aspect-[8.5/11] w-full animate-pulse space-y-4 p-8">
      <!-- Header line -->
      <div class="h-6 w-3/4 rounded bg-gray-300 dark:bg-gray-600"></div>

      <!-- Content lines -->
      <div class="space-y-3 pt-4">
        <div class="h-4 w-full rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-11/12 rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-full rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-10/12 rounded bg-gray-200 dark:bg-gray-700"></div>
      </div>

      <!-- Content blocks -->
      <div class="space-y-3 pt-6">
        <div class="h-4 w-full rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-full rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-9/12 rounded bg-gray-200 dark:bg-gray-700"></div>
      </div>

      <div class="space-y-3 pt-6">
        <div class="h-5 w-2/3 rounded bg-gray-300 dark:bg-gray-600"></div>
        <div class="h-4 w-full rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-full rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-11/12 rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-10/12 rounded bg-gray-200 dark:bg-gray-700"></div>
      </div>

      <div class="space-y-3 pt-6">
        <div class="h-5 w-1/2 rounded bg-gray-300 dark:bg-gray-600"></div>
        <div class="h-4 w-full rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-full rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-4 w-9/12 rounded bg-gray-200 dark:bg-gray-700"></div>
      </div>
    </div>
  </div>
</div>
